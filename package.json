{
  "name": "@danipa/sdk",
  "version": "0.2.0-rc.0",
  "description": "Official Node.js SDK for the Danipa payments API — collections, disbursements, wallets, payment links, invoices, webhook verification.",
  "license": "MIT",
  "homepage": "https://developer.danipa.com/sdks",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Danipa/node-sdk.git"
  },
  "bugs": {
    "url": "https://github.com/Danipa/node-sdk/issues"
  },
  "keywords": [
    "danipa",
    "payments",
    "fintech",
    "africa",
    "mtn-momo",
    "stripe",
    "remittance"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./webhook": {
      "types": "./dist/webhook.d.ts",
      "import": "./dist/webhook.js",
      "require": "./dist/webhook.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run typecheck && npm run test && npm run build"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "tsup": "^8.3.0",
    "typescript": "^5.6.0",
    "vitest": "^4.0.0"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
